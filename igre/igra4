<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Pi Memory Game</title>
<style>
    body {
        margin: 0;
        background: #111;
        color: white;
        font-family: Arial;
        text-align: center;
    }
    canvas {
        background: #222;
        display: block;
        margin: auto;
    }
</style>
</head>
<body>

<canvas id="gameCanvas" width="800" height="600"></canvas>

<script>
const canvas = document.getElementById("gameCanvas");
const ctx = canvas.getContext("2d");

let state = "menu";

// ---- PI SEQUENCE ----
const pi_digits = "14159265358979323846264338327950288419716939937510582097494459230781640628620899862803482534211706798214808651328230664709384460955058223172535940812848111745028410270193";

function getPiDigit(index) {
    return Number(pi_digits[index - 1]);
}

// ---- GAME STATE ----
let maxTime = 5;
let timeLeft = maxTime;
let currentIndex = 1;
let score = 0;
let buttons = [];

// ---- GAME LOGIC ----
function startGame() {
    timeLeft = 5;
    currentIndex = 1;
    score = 0;
    generateOptions();
}

function generateOptions() {
    let correct = getPiDigit(currentIndex);
    let options = [correct];

    while (options.length < 4) {
        let r = Math.floor(Math.random() * 10);
        if (!options.includes(r)) {
            options.push(r);
        }
    }

    // shuffle
    for (let i = options.length - 1; i > 0; i--) {
        let j = Math.floor(Math.random() * (i + 1));
        [options[i], options[j]] = [options[j], options[i]];
    }

    buttons = [];

    for (let i = 0; i < 4; i++) {
        buttons.push({
            x: (i % 2) * 350 + 75,
            y: Math.floor(i / 2) * 200 + 200,
            w: 300,
            h: 150,
            value: options[i]
        });
    }
}

// ---- UPDATE LOOP ----
let lastTime = 0;

function update(timestamp) {
    let dt = (timestamp - lastTime) / 1000;
    lastTime = timestamp;

    if (state === "game") {
        if (timeLeft > 0) {
            timeLeft -= dt;
            if (timeLeft <= 0) {
                timeLeft = 0;
                state = "deathscreen";
            }
        }
    }

    draw();
    requestAnimationFrame(update);
}

// ---- DRAWING ----
function draw() {
    ctx.clearRect(0, 0, 800, 600);

    ctx.fillStyle = "white";
    ctx.strokeStyle = "white";

    if (state === "menu") drawMenu();
    else if (state === "game") drawGame();
    else if (state === "deathscreen") drawDeath();
}

// MENU
function drawMenu() {
    ctx.font = "30px Arial";
    ctx.textAlign = "center";
    ctx.fillText("PI MEMORY GAME", 400, 200);

    ctx.strokeRect(300, 350, 200, 80);
    ctx.fillText("START", 400, 400);
}

// GAME
function drawGame() {
    // timer bar
    let percent = timeLeft / maxTime;

    ctx.strokeRect(200, 30, 400, 30);
    ctx.fillRect(200, 30, 400 * percent, 30);

    ctx.textAlign = "left";
    ctx.font = "20px Arial";
    ctx.fillText("Score: " + score, 20, 30);

    ctx.textAlign = "center";
    ctx.font = "24px Arial";
    ctx.fillText("3." + pi_digits.substring(0, currentIndex - 1), 400, 120);

    // buttons
    buttons.forEach(b => {
        ctx.strokeRect(b.x, b.y, b.w, b.h);
        ctx.fillText(b.value, b.x + b.w / 2, b.y + 85);
    });
}

// DEATH SCREEN
function drawDeath() {
    ctx.textAlign = "center";
    ctx.font = "30px Arial";
    ctx.fillText("GAME OVER", 400, 200);

    ctx.font = "20px Arial";
    ctx.fillText("Digits remembered: " + score, 400, 260);

    ctx.strokeRect(300, 350, 200, 80);
    ctx.fillText("MENU", 400, 400);
}

// ---- INPUT ----
canvas.addEventListener("click", function(e) {
    let rect = canvas.getBoundingClientRect();
    let x = e.clientX - rect.left;
    let y = e.clientY - rect.top;

    if (state === "menu") {
        if (x > 300 && x < 500 && y > 350 && y < 430) {
            startGame();
            state = "game";
        }
    }

    else if (state === "game") {
        buttons.forEach(b => {
            if (x > b.x && x < b.x + b.w && y > b.y && y < b.y + b.h) {
                let correct = getPiDigit(currentIndex);

                if (b.value === correct) {
                    score++;
                    currentIndex++;
                    generateOptions();

                    timeLeft += 1;
                    if (timeLeft > maxTime) timeLeft = maxTime;
                } else {
                    state = "deathscreen";
                }
            }
        });
    }

    else if (state === "deathscreen") {
        if (x > 300 && x < 500 && y > 350 && y < 430) {
            state = "menu";
        }
    }
});

// START LOOP
requestAnimationFrame(update);
</script>

</body>
</html>
